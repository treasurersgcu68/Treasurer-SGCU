[debug] [2026-03-31T06:39:28.731Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/departmentwebsite-5aec1/rulesets {"name":"projects/departmentwebsite-5aec1/rulesets/7a25e00b-3193-4cff-bd68-66a760472f75","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isStaff() {\n      return isSignedIn() && (\n        request.auth.token.staff == true ||\n        request.auth.token.isStaff == true ||\n        request.auth.token.role in [\"staff\", \"admin\"] ||\n        (\n          request.auth.token.email is string &&\n          request.auth.token.email in [\n            \"treasurer.sgcu68@gmail.com\",\n            \"6534324223@student.chula.ac.th\"\n          ]\n        )\n      );\n    }\n\n    function isRequester(resourceData) {\n      return isSignedIn() &&\n        request.auth.token.email is string &&\n        resourceData.requesterEmail is string &&\n        request.auth.token.email == resourceData.requesterEmail;\n    }\n\n    function hasBookingCreateFields() {\n      return request.resource.data.keys().hasAll([\n        \"roomId\",\n        \"roomName\",\n        \"date\",\n        \"startTime\",\n        \"endTime\",\n        \"requester\",\n        \"purpose\",\n        \"requesterEmail\",\n        \"status\",\n        \"startAt\",\n        \"endAt\",\n        \"createdAt\",\n        \"updatedAt\"\n      ]);\n    }\n\n    function isValidBookingStatus(status) {\n      return status in [\"pending\", \"approved\", \"rejected\", \"cancel_requested\", \"reschedule_requested\"];\n    }\n\n    function requesterAllowedBookingUpdate() {\n      return request.resource.data.diff(resource.data).changedKeys().hasOnly([\n        \"status\",\n        \"cancelledByRequester\",\n        \"cancelRequestReason\",\n        \"cancelledAt\",\n        \"rescheduleBaseStatus\",\n        \"rescheduleRequestedDate\",\n        \"rescheduleRequestedStartTime\",\n        \"rescheduleRequestedEndTime\",\n        \"rescheduleRequestReason\",\n        \"updatedAt\"\n      ]);\n    }\n\n    match /meetingRoomBookings/{bookingId} {\n      allow read: if isSignedIn();\n\n      allow create: if isSignedIn() &&\n        hasBookingCreateFields() &&\n        request.resource.data.requesterEmail == request.auth.token.email &&\n        isValidBookingStatus(request.resource.data.status);\n\n      allow update: if (\n        isStaff() && isValidBookingStatus(request.resource.data.status)\n      ) || (\n        isRequester(resource.data) &&\n        requesterAllowedBookingUpdate() &&\n        isValidBookingStatus(request.resource.data.status)\n      );\n\n      allow delete: if isStaff();\n    }\n\n    match /meetingRooms/{roomId} {\n      allow read: if isSignedIn();\n      allow create, update, delete: if isStaff();\n    }\n\n    match /meetingRoomHolidays/{holidayId} {\n      allow read: if isSignedIn();\n      allow create, update, delete: if isStaff();\n    }\n\n    match /auditLogs/{logId} {\n      allow create: if isSignedIn() && (\n        isStaff() || request.resource.data.actorUid == request.auth.uid\n      );\n      allow read: if isStaff();\n      allow update, delete: if false;\n    }\n\n    // Public visitor counter (used on home page without auth)\n    match /site_daily_visitors/{dateKey} {\n      allow read: if true;\n      allow create, update: if\n        request.resource.data.keys().hasOnly([\"total\", \"updatedAt\"]) &&\n        request.resource.data.total is int &&\n        request.resource.data.total >= 0;\n      allow delete: if false;\n    }\n\n    match /site_stats/{statId} {\n      allow read: if true;\n      allow create, update: if\n        statId == \"visitors_all_time\" &&\n        request.resource.data.keys().hasOnly([\"total\", \"updatedAt\"]) &&\n        request.resource.data.total is int &&\n        request.resource.data.total >= 0;\n      allow delete: if false;\n    }\n\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-03-31T06:39:28.800143Z","metadata":{"services":["cloud.firestore"]}}
