rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && allowedAuthenticatedEmail();
    }

    function rawAuthEmail() {
      return request.auth != null && request.auth.token.email is string
        ? request.auth.token.email
        : "";
    }

    function allowedAuthenticatedEmail() {
      return rawAuthEmail().matches(".*@([^@]+\\.)?chula\\.ac\\.th$") ||
        rawAuthEmail() in [
          "tuwanon.kimchiang@gmail.com"
        ] ||
        hasValidTemporaryAuthEmailAccess(rawAuthEmail());
    }

    function authEmailAccessPath(email) {
      return /databases/$(database)/documents/authEmailAccess/$(email);
    }

    function validTemporaryAuthEmailAccessData(data) {
      return data.active == true &&
        data.email == rawAuthEmail() &&
        data.startsAt is timestamp &&
        data.endsAt is timestamp &&
        data.startsAt <= request.time &&
        data.endsAt > request.time;
    }

    function hasValidTemporaryAuthEmailAccess(email) {
      return request.auth != null &&
        email is string &&
        exists(authEmailAccessPath(email)) &&
        validTemporaryAuthEmailAccessData(get(authEmailAccessPath(email)).data);
    }

    function userEmail() {
      return signedIn() ? rawAuthEmail() : "";
    }

    function userUid() {
      return signedIn() ? request.auth.uid : "";
    }

    function isBootstrapHeadStaff() {
      return userEmail() in [
        "tuwanon.kimchiang@gmail.com",
        "treasurer.sgcu68@gmail.com"
      ];
    }

    function staffProfilePath() {
      return /databases/$(database)/documents/staffProfiles/$(userEmail());
    }

    function hasStaffProfile() {
      return signedIn() && exists(staffProfilePath());
    }

    function staffProfile() {
      return get(staffProfilePath()).data;
    }

    function isStaff() {
      return isBootstrapHeadStaff() ||
        (
          hasStaffProfile() &&
          (
            staffProfile().role is string ||
            staffProfile().positionCodeYY is string ||
            staffProfile().divisionCodeYY is string ||
            staffProfile().positions is list
          )
        );
    }

    function isHeadStaff() {
      return isBootstrapHeadStaff() ||
        (
          hasStaffProfile() &&
          (
            staffProfile().role == "0" ||
            staffProfile().positionCodeYY == "00" ||
            staffProfile().divisionCodeYY == "00" ||
            (
              staffProfile().divisionCodesYY is list &&
              staffProfile().divisionCodesYY.hasAny(["00"])
            ) ||
            (
              staffProfile().position is string &&
              staffProfile().position.matches(".*เหรัญญิก.*")
            )
          )
        );
    }

    function isOwnerByUid(uid) {
      return signedIn() && uid == userUid();
    }

    function isOwnerByEmail(email) {
      return signedIn() && email == userEmail();
    }

    function unchanged(field) {
      return !(field in request.resource.data) ||
        (field in resource.data && request.resource.data[field] == resource.data[field]);
    }

    function onlyChanged(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function validAuditLogSnapshot(value) {
      return value == null || value is map || value is list;
    }

    function validAuditLogAction(action) {
      return action in [
        "budget.settings.update",
        "budget.round.delete",
        "budget.project_codes.run",
        "budget.project_codes.clear",
        "budget.request.create",
        "budget.request.update",
        "budget.request.cancel",
        "budget.request.delete",
        "borrow.request.create",
        "borrow.request.status_update",
        "borrow.request.delete",
        "content.news.create",
        "content.news.update",
        "content.news.import",
        "content.document.create",
        "content.document.update",
        "content.document.import",
        "content.document.reorder",
        "booking.created",
        "booking.status_updated",
        "booking.status_updated_by_staff",
        "booking.deleted_by_staff",
        "booking.cancelled_by_requester",
        "booking.reschedule_requested",
        "meeting_room.created",
        "meeting_room.deleted",
        "meeting_room.renamed",
        "meeting_room.booking_access_updated",
        "meeting_holiday.created",
        "meeting_holiday.deleted",
        "staff.auth_access.upsert",
        "staff.auth_access.delete",
        "staff.position.create",
        "staff.position.update",
        "staff.position.delete",
        "staff.application.create",
        "staff.application.status_update",
        "staff.application.revoke",
        "staff.application.position_update",
        "staff.application.delete",
        "staff.org_representative.status_update",
        "staff.org_representative.delete",
        "staff.organization_catalog.upsert",
        "staff.organization_catalog.archive",
        "staff.organization_catalog.import"
      ];
    }

    function validAuditLogEntityType(entityType) {
      return entityType in [
        "budgetApprovalRequest",
        "budgetApprovalSettings",
        "borrowAssetRequest",
        "newsItem",
        "downloadDocument",
        "meetingRoomBooking",
        "meetingRoom",
        "meetingRoomHoliday",
        "authEmailAccess",
        "staffPosition",
        "staffApplication",
        "orgRepresentativeApplication",
        "organizationCatalogItem"
      ];
    }

    function auditLogActionRequiresStaff(action) {
      return action in [
        "budget.settings.update",
        "budget.round.delete",
        "budget.project_codes.run",
        "budget.project_codes.clear",
        "budget.request.cancel",
        "borrow.request.status_update",
        "borrow.request.delete",
        "content.news.create",
        "content.news.update",
        "content.news.import",
        "content.document.create",
        "content.document.update",
        "content.document.import",
        "content.document.reorder",
        "booking.status_updated_by_staff",
        "booking.deleted_by_staff",
        "meeting_room.created",
        "meeting_room.deleted",
        "meeting_room.renamed",
        "meeting_room.booking_access_updated",
        "meeting_holiday.created",
        "meeting_holiday.deleted",
        "staff.auth_access.upsert",
        "staff.auth_access.delete",
        "staff.position.create",
        "staff.position.update",
        "staff.position.delete",
        "staff.application.status_update",
        "staff.application.revoke",
        "staff.application.position_update",
        "staff.application.delete",
        "staff.org_representative.status_update",
        "staff.org_representative.delete",
        "staff.organization_catalog.upsert",
        "staff.organization_catalog.archive",
        "staff.organization_catalog.import"
      ];
    }

    function validAuditLogCreate() {
      return request.resource.data.keys().hasOnly([
          "action",
          "entityType",
          "entityId",
          "before",
          "after",
          "actorUid",
          "actorEmail",
          "actorDisplayName",
          "actorRole",
          "source",
          "metadata",
          "timestamp"
        ]) &&
        request.resource.data.action is string &&
        validAuditLogAction(request.resource.data.action) &&
        request.resource.data.entityType is string &&
        validAuditLogEntityType(request.resource.data.entityType) &&
        request.resource.data.entityId is string &&
        validAuditLogSnapshot(request.resource.data.before) &&
        validAuditLogSnapshot(request.resource.data.after) &&
        request.resource.data.actorUid == userUid() &&
        request.resource.data.actorEmail == userEmail() &&
        (!("actorDisplayName" in request.resource.data) || request.resource.data.actorDisplayName is string) &&
        request.resource.data.actorRole is string &&
        request.resource.data.source in ["web_app", "web_app_staff"] &&
        (request.resource.data.source != "web_app_staff" || isStaff()) &&
        (!auditLogActionRequiresStaff(request.resource.data.action) || isStaff()) &&
        request.resource.data.metadata is map &&
        request.resource.data.timestamp == request.time;
    }

    match /userProfiles/{uid} {
      allow read: if isOwnerByUid(uid) || isStaff();
      allow create, update: if isOwnerByUid(uid) &&
        request.resource.data.uid == userUid() &&
        request.resource.data.email == userEmail();
      allow delete: if false;
    }

    match /authEmailAccess/{email} {
      allow get: if request.auth != null &&
        email == rawAuthEmail() &&
        hasValidTemporaryAuthEmailAccess(email);
      allow list, create, update, delete: if isHeadStaff();
    }

    match /staffProfiles/{email} {
      allow read: if isStaff() || isOwnerByEmail(email);
      allow create, update, delete: if isHeadStaff();
    }

    match /staffApplications/{applicationId} {
      allow create: if signedIn() &&
        request.resource.data.applicantUid == userUid() &&
        request.resource.data.applicantEmail == userEmail() &&
        request.resource.data.status == "pending";
      allow read: if isStaff() ||
        isOwnerByUid(resource.data.applicantUid) ||
        isOwnerByEmail(resource.data.applicantEmail);
      allow update, delete: if isHeadStaff();
    }

    match /organizationRepresentativeApplications/{applicationId} {
      allow create: if signedIn() &&
        request.resource.data.applicantUid == userUid() &&
        request.resource.data.applicantEmail == userEmail() &&
        request.resource.data.status == "pending";
      allow read: if isStaff() ||
        isOwnerByUid(resource.data.applicantUid) ||
        isOwnerByEmail(resource.data.applicantEmail);
      allow update, delete: if isHeadStaff();
    }

    match /staffPositionCatalog/{positionId} {
      allow read: if signedIn();
      allow create, update, delete: if isHeadStaff();
    }

    match /staffPositionCodeCounters/{counterId} {
      allow read, create, update: if isHeadStaff();
      allow delete: if false;
    }

    function validBorrowStatus(status) {
      return status in ["pending", "approved", "received", "rejected", "cancelled", "returned"];
    }

    function canCreateBorrowRequest() {
      return signedIn() &&
        request.resource.data.requesterEmail == userEmail() &&
        request.resource.data.status == "pending" &&
        validBorrowStatus(request.resource.data.status);
    }

    function canReadBorrowRequest() {
      return isStaff() || isOwnerByEmail(resource.data.requesterEmail);
    }

    function canUserCancelBorrowRequest() {
      return isOwnerByEmail(resource.data.requesterEmail) &&
        resource.data.status == "pending" &&
        request.resource.data.status == "cancelled" &&
        unchanged("requesterEmail") &&
        onlyChanged(["status", "updatedAt"]);
    }

    function canStaffUpdateBorrowRequest() {
      return isStaff() &&
        validBorrowStatus(request.resource.data.status) &&
        unchanged("requesterEmail");
    }

    match /borrowAssetCatalog/{assetCode} {
      allow get, list: if isStaff() ||
        resource.data.approved == true ||
        resource.data.status == "active";
      allow create, update, delete: if isStaff();
    }

    match /borrowAssetRequests/{requestId} {
      allow create: if canCreateBorrowRequest();
      allow get: if canReadBorrowRequest();
      allow list: if canReadBorrowRequest();
      allow update: if canStaffUpdateBorrowRequest() || canUserCancelBorrowRequest();
      allow delete: if isStaff();
    }

    match /borrowAssetStockReservations/{assetCode} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if false;
    }

    function validBudgetStatus(status) {
      return status in ["pending", "reviewing", "approved", "rejected", "cancelled"];
    }

    function canAuthenticatedUserUpdatePendingBudgetRequest() {
      return signedIn() &&
        resource.data.status == "pending" &&
        validBudgetStatus(request.resource.data.status) &&
        unchanged("status") &&
        unchanged("requestType") &&
        unchanged("organizationType") &&
        unchanged("organizationName") &&
        unchanged("representative") &&
        unchanged("requester") &&
        unchanged("requesterEmail");
    }

    function canAuthenticatedUserDeletePendingBudgetRequest() {
      return signedIn() &&
        resource.data.status == "pending";
    }

    match /budgetApprovalRequests/{requestId} {
      allow create: if signedIn() &&
        (
          isStaff() ||
          (
            (
              request.resource.data.requester.email == userEmail() ||
              request.resource.data.requesterEmail == userEmail()
            ) &&
            request.resource.data.status == "pending"
          )
        ) &&
        validBudgetStatus(request.resource.data.status);
      allow read: if isStaff() ||
        signedIn() ||
        isOwnerByEmail(resource.data.requester.email) ||
        isOwnerByEmail(resource.data.requesterEmail);
      allow update: if isStaff() ||
        canAuthenticatedUserUpdatePendingBudgetRequest() ||
        (
          (
            isOwnerByEmail(resource.data.requester.email) ||
            isOwnerByEmail(resource.data.requesterEmail)
          ) &&
          resource.data.status == "pending" &&
          validBudgetStatus(request.resource.data.status) &&
          unchanged("status") &&
          unchanged("requester") &&
          unchanged("requesterEmail")
        );
      allow delete: if isStaff() ||
        canAuthenticatedUserDeletePendingBudgetRequest();
    }

    match /budgetApprovalSettings/{settingsId} {
      allow read: if signedIn();
      allow create, update, delete: if isStaff();
    }

    match /newsItems/{newsId} {
      allow get, list: if resource.data.status == "published" || isStaff();
      allow create, update, delete: if isStaff();
    }

    match /orgStructureMembers/{memberId} {
      allow get, list: if resource.data.status == "published" || isStaff();
      allow create, update, delete: if isHeadStaff();
    }

    match /organizationCatalog/{orgId} {
      allow get, list: if resource.data.status == "active" || isStaff();
      allow create, update, delete: if isStaff();
    }

    match /downloadDocuments/{documentId} {
      allow get, list: if resource.data.status == "published" || isStaff();
      allow create, update, delete: if isStaff();
    }

    match /publicCache/{cacheId} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    match /meetingRoomBookings/{bookingId} {
      allow read: if true;
      allow create: if signedIn() &&
        request.resource.data.requesterEmail == userEmail() &&
        request.resource.data.status == "pending";
      allow update: if isStaff() ||
        (
          isOwnerByEmail(resource.data.requesterEmail) &&
          unchanged("requesterEmail") &&
          request.resource.data.status in ["rejected", "cancel_requested", "reschedule_requested"]
        );
      allow delete: if isStaff();
    }

    match /meetingRooms/{roomId} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    match /meetingRoomHolidays/{holidayId} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    match /auditLogs/{logId} {
      allow create: if signedIn() && validAuditLogCreate();
      allow read: if isStaff();
      allow update, delete: if false;
    }

    match /appSettings/{settingsId} {
      allow read: if true;
      allow create, update, delete: if isHeadStaff();
    }

    function validVisitorCounterWrite(counterPath) {
      return request.resource.data.keys().hasOnly(["total", "updatedAt"]) &&
        request.resource.data.total is int &&
        request.resource.data.total >= 1 &&
        (
          !exists(counterPath) ||
          request.resource.data.total == resource.data.total + 1
        );
    }

    match /site_daily_visitors/{dateId} {
      allow read: if true;
      allow create, update: if validVisitorCounterWrite(
        /databases/$(database)/documents/site_daily_visitors/$(dateId)
      );
      allow delete: if false;
    }

    match /site_stats/{statId} {
      allow read: if true;
      allow create, update: if validVisitorCounterWrite(
        /databases/$(database)/documents/site_stats/$(statId)
      );
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
