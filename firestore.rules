rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isStaff() {
      return isSignedIn() && (
        request.auth.token.staff == true ||
        request.auth.token.isStaff == true ||
        request.auth.token.role in ["staff", "admin"] ||
        (
          request.auth.token.email is string &&
          request.auth.token.email in [
            "treasurer.sgcu68@gmail.com",
            "6534324223@student.chula.ac.th"
          ]
        )
      );
    }

    function isRequester(resourceData) {
      return isSignedIn() &&
        request.auth.token.email is string &&
        resourceData.requesterEmail is string &&
        request.auth.token.email == resourceData.requesterEmail;
    }

    function hasBookingCreateFields() {
      return request.resource.data.keys().hasAll([
        "roomId",
        "roomName",
        "date",
        "startTime",
        "endTime",
        "requester",
        "purpose",
        "requesterEmail",
        "status",
        "startAt",
        "endAt",
        "createdAt",
        "updatedAt"
      ]);
    }

    function isValidBookingStatus(status) {
      return status in ["pending", "approved", "rejected", "cancel_requested", "reschedule_requested"];
    }

    function requesterAllowedBookingUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "status",
        "cancelledByRequester",
        "cancelRequestReason",
        "cancelledAt",
        "rescheduleBaseStatus",
        "rescheduleRequestedDate",
        "rescheduleRequestedStartTime",
        "rescheduleRequestedEndTime",
        "rescheduleRequestReason",
        "updatedAt"
      ]);
    }

    match /meetingRoomBookings/{bookingId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        hasBookingCreateFields() &&
        request.resource.data.requesterEmail == request.auth.token.email &&
        isValidBookingStatus(request.resource.data.status);

      allow update: if (
        isStaff() && isValidBookingStatus(request.resource.data.status)
      ) || (
        isRequester(resource.data) &&
        requesterAllowedBookingUpdate() &&
        isValidBookingStatus(request.resource.data.status)
      );

      allow delete: if isStaff();
    }

    match /meetingRooms/{roomId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isStaff();
    }

    match /meetingRoomHolidays/{holidayId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isStaff();
    }

    match /auditLogs/{logId} {
      allow create: if isSignedIn() && (
        isStaff() || request.resource.data.actorUid == request.auth.uid
      );
      allow read: if isStaff();
      allow update, delete: if false;
    }

    // Public visitor counter (used on home page without auth)
    match /site_daily_visitors/{dateKey} {
      allow read: if true;
      allow create, update: if
        request.resource.data.keys().hasOnly(["total", "updatedAt"]) &&
        request.resource.data.total is int &&
        request.resource.data.total >= 0;
      allow delete: if false;
    }

    match /site_stats/{statId} {
      allow read: if true;
      allow create, update: if
        statId == "visitors_all_time" &&
        request.resource.data.keys().hasOnly(["total", "updatedAt"]) &&
        request.resource.data.total is int &&
        request.resource.data.total >= 0;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
